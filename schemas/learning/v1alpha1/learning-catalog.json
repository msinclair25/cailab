{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudailab.dev/schemas/learning/v1alpha1/learning-catalog.json",
  "title": "CloudAILab Learning Catalog v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "commonCore", "lessons", "paths"],
  "properties": {
    "apiVersion": { "const": "cloudailab.dev/learning/v1alpha1" },
    "kind": { "const": "LearningCatalog" },
    "commonCore": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/coreOutcome" } },
    "lessons": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/lesson" } },
    "paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path" } }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
    "nonEmpty": { "type": "string", "minLength": 1 },
    "coreOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "title": { "$ref": "#/$defs/nonEmpty" },
        "description": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "track", "difficulty", "durationMinutes", "prerequisites", "commonCore", "safetyBoundary", "binding", "outcomes", "missionLayers", "hints", "verification", "cleanup", "productionContext", "reflection"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "title": { "$ref": "#/$defs/nonEmpty" },
        "track": { "enum": ["common_core", "cloud_devops", "iam_security", "platform_engineering", "security_operations", "ai_governance", "community_authoring"] },
        "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
        "durationMinutes": { "type": "integer", "minimum": 5, "maximum": 480 },
        "prerequisites": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
        "commonCore": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
        "safetyBoundary": { "enum": ["read_only", "local_no_docker", "local_docker", "trusted_host_process"] },
        "binding": { "$ref": "#/$defs/binding" },
        "outcomes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmpty" } },
        "missionLayers": { "$ref": "#/$defs/missionLayers" },
        "hints": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "$ref": "#/$defs/hint" } },
        "verification": { "$ref": "#/$defs/verification" },
        "cleanup": { "$ref": "#/$defs/cleanup" },
        "productionContext": { "$ref": "#/$defs/nonEmpty" },
        "reflection": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmpty" } }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "guide"],
      "properties": {
        "type": { "enum": ["scenario", "workflow"] },
        "id": { "$ref": "#/$defs/identifier" },
        "guide": { "type": "string", "pattern": "^(?:docs|examples)/[^\\r\\n]+\\.md$" }
      }
    },
    "missionLayers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delivery", "identity", "runtimeResource", "data", "evidenceGovernance", "remediation"],
      "properties": {
        "delivery": { "$ref": "#/$defs/layerCoverage" },
        "identity": { "$ref": "#/$defs/layerCoverage" },
        "runtimeResource": { "$ref": "#/$defs/layerCoverage" },
        "data": { "$ref": "#/$defs/layerCoverage" },
        "evidenceGovernance": { "$ref": "#/$defs/layerCoverage" },
        "remediation": { "$ref": "#/$defs/layerCoverage" }
      }
    },
    "layerCoverage": { "enum": ["covered", "supporting", "not_applicable"] },
    "hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "text"],
      "properties": {
        "level": { "type": "integer", "minimum": 1, "maximum": 3 },
        "text": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "commands"],
      "properties": {
        "type": { "enum": ["cli", "evidence"] },
        "commands": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmpty" } }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "commands"],
      "properties": {
        "required": { "type": "boolean" },
        "commands": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } }
      }
    },
    "path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "audience", "description", "lessons"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "title": { "$ref": "#/$defs/nonEmpty" },
        "audience": { "$ref": "#/$defs/nonEmpty" },
        "description": { "$ref": "#/$defs/nonEmpty" },
        "lessons": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } }
      }
    }
  }
}
