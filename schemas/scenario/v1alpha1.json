{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudailab.dev/schemas/scenario/v1alpha1.json",
  "title": "CloudAILab Scenario v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "cloudailab.dev/v1alpha1" },
    "kind": { "const": "Scenario" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "title"],
      "properties": {
        "name": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "briefing",
        "objectives",
        "tenants",
        "principals",
        "resources",
        "relationships",
        "verification"
      ],
      "properties": {
        "seed": { "type": "integer" },
        "briefing": { "type": "string", "minLength": 1 },
        "runtimes": { "$ref": "#/$defs/runtimes" },
        "providers": { "$ref": "#/$defs/providers" },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/objective" }
        },
        "tenants": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/tenant" }
        },
        "principals": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/principal" }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/resource" }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/relationship" }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["invariants"],
          "properties": {
            "invariants": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/invariant" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._:-]{0,127}$"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$"
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "runtimes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aws": {
          "type": "object",
          "additionalProperties": false,
          "required": ["engine", "image", "iamEnforcement"],
          "properties": {
            "engine": { "const": "floci" },
            "image": {
              "const": "floci/floci:1.5.32@sha256:4f69631e560120d79ad82d2af9f7dda8c6ef7ecbbae0c43ddcffa109c6588a15"
            },
            "iamEnforcement": { "type": "boolean" }
          }
        },
        "microsoft": {
          "type": "object",
          "additionalProperties": false,
          "required": ["engine"],
          "properties": {
            "engine": { "const": "native" }
          }
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aws": { "$ref": "#/$defs/awsProvider" },
        "microsoft": { "$ref": "#/$defs/microsoftProvider" }
      }
    },
    "microsoftProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant", "tenantId", "users", "applications", "servicePrincipals", "oauth2PermissionGrants"],
      "properties": {
        "tenant": { "$ref": "#/$defs/id" },
        "tenantId": { "$ref": "#/$defs/uuid" },
        "users": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/microsoftUser" }
        },
        "applications": {
          "type": "array",
          "items": { "$ref": "#/$defs/microsoftApplication" }
        },
        "servicePrincipals": {
          "type": "array",
          "items": { "$ref": "#/$defs/microsoftServicePrincipal" }
        },
        "oauth2PermissionGrants": {
          "type": "array",
          "items": { "$ref": "#/$defs/microsoftPermissionGrant" }
        }
      }
    },
    "microsoftUser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "id", "displayName", "userPrincipalName"],
      "properties": {
        "node": { "$ref": "#/$defs/id" },
        "id": { "$ref": "#/$defs/uuid" },
        "displayName": { "type": "string", "minLength": 1 },
        "userPrincipalName": { "type": "string", "pattern": "^[^@\\s]+@[^@\\s]+$" }
      }
    },
    "microsoftApplication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "id", "appId", "displayName"],
      "properties": {
        "node": { "$ref": "#/$defs/id" },
        "id": { "$ref": "#/$defs/uuid" },
        "appId": { "$ref": "#/$defs/uuid" },
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "microsoftServicePrincipal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "appId", "displayName"],
      "oneOf": [
        { "required": ["node"], "not": { "required": ["resourceNode"] } },
        { "required": ["resourceNode"], "not": { "required": ["node"] } }
      ],
      "properties": {
        "node": { "$ref": "#/$defs/id" },
        "resourceNode": { "$ref": "#/$defs/id" },
        "id": { "$ref": "#/$defs/uuid" },
        "appId": { "$ref": "#/$defs/uuid" },
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "microsoftPermissionGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "clientId", "consentType", "principalId", "resourceId", "scope"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "clientId": { "$ref": "#/$defs/uuid" },
        "consentType": { "const": "Principal" },
        "principalId": { "$ref": "#/$defs/uuid" },
        "resourceId": { "$ref": "#/$defs/uuid" },
        "scope": { "type": "string", "minLength": 1 }
      }
    },
    "awsProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region", "accounts", "roles", "buckets"],
      "properties": {
        "region": { "type": "string", "pattern": "^[a-z]{2}(-gov)?-[a-z]+-[0-9]$" },
        "accounts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/awsAccount" }
        },
        "roles": {
          "type": "array",
          "items": { "$ref": "#/$defs/awsRole" }
        },
        "buckets": {
          "type": "array",
          "items": { "$ref": "#/$defs/awsBucket" }
        }
      }
    },
    "awsAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tenant", "principal"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9]{12}$" },
        "tenant": { "$ref": "#/$defs/id" },
        "principal": { "$ref": "#/$defs/id" }
      }
    },
    "awsRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "account", "name", "trust"],
      "properties": {
        "node": { "$ref": "#/$defs/id" },
        "account": { "type": "string", "pattern": "^[0-9]{12}$" },
        "name": { "type": "string", "pattern": "^[A-Za-z0-9_+=,.@-]{1,64}$" },
        "trust": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "policies": {
          "type": "array",
          "items": { "$ref": "#/$defs/awsInlinePolicy" }
        }
      }
    },
    "awsInlinePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "statements"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Za-z0-9_+=,.@-]{1,64}$" },
        "statements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/awsPolicyStatement" }
        }
      }
    },
    "awsPolicyStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect", "actions", "resources"],
      "properties": {
        "effect": { "enum": ["Allow", "Deny"] },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "awsBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "account", "name"],
      "properties": {
        "node": { "$ref": "#/$defs/id" },
        "account": { "type": "string", "pattern": "^[0-9]{12}$" },
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$" },
        "objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/awsObject" }
        }
      }
    },
    "awsObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "data"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "data": { "type": "string" }
      }
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "providers"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "providers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["aws", "microsoft", "google", "local"] }
        }
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tenant", "type", "displayName"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "tenant": { "$ref": "#/$defs/id" },
        "type": { "enum": ["human", "group", "workload", "application", "service", "agent"] },
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tenant", "type", "displayName", "classification"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "tenant": { "$ref": "#/$defs/id" },
        "type": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "classification": { "enum": ["public", "internal", "confidential", "restricted"] }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "from": { "$ref": "#/$defs/id" },
        "to": { "$ref": "#/$defs/id" },
        "type": {
          "enum": ["member_of", "synchronized_to", "assigned_to", "federates_as", "can_access", "owns"]
        },
        "actions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "from", "to", "severity", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "enum": ["path_exists", "path_absent"] },
        "from": { "$ref": "#/$defs/id" },
        "to": { "$ref": "#/$defs/id" },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
