{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudailab.dev/schemas/agent/v1alpha1/governance-policy.json",
  "title": "CloudAILab Governance Policy v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "version", "defaultEffect", "rules"],
  "properties": {
    "apiVersion": { "const": "cloudailab.dev/agent/v1alpha1" },
    "kind": { "const": "GovernancePolicy" },
    "version": { "$ref": "#/$defs/version" },
    "defaultEffect": { "const": "deny" },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "pointer": { "type": "string", "pattern": "^/(?:[^~]|~[01])*$" },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "effect", "agentId", "tool", "action", "resource", "resourceTenant", "resourceClassification"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "effect": { "enum": ["allow", "deny", "redact", "require_approval"] },
        "agentId": { "$ref": "#/$defs/id" },
        "tool": { "$ref": "#/$defs/id" },
        "action": { "type": "string", "minLength": 1 },
        "resource": { "$ref": "#/$defs/id" },
        "resourceTenant": { "$ref": "#/$defs/id" },
        "resourceClassification": { "enum": ["public", "internal", "confidential", "restricted"] },
        "redactions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/pointer" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "effect": { "const": "redact" } } },
          "then": { "required": ["redactions"] },
          "else": { "not": { "required": ["redactions"] } }
        }
      ]
    }
  }
}
