{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudailab.dev/schemas/agent/v1alpha1/approval-resolution-event.json",
  "title": "CloudAILab Approval Resolution Event v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "eventId", "occurredAt", "runId", "trialId", "correlationId", "approvalId", "decisionEventId", "resolvedBy", "approved", "tool", "action", "resource", "decision", "inputHash"],
  "properties": {
    "apiVersion": { "const": "cloudailab.dev/agent/v1alpha1" },
    "kind": { "const": "ApprovalResolutionEvent" },
    "eventId": { "$ref": "#/$defs/id" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "runId": { "$ref": "#/$defs/id" },
    "trialId": { "$ref": "#/$defs/id" },
    "correlationId": { "$ref": "#/$defs/id" },
    "approvalId": { "$ref": "#/$defs/id" },
    "decisionEventId": { "$ref": "#/$defs/id" },
    "resolvedBy": { "$ref": "#/$defs/id" },
    "approved": { "type": "boolean" },
    "tool": { "$ref": "#/$defs/toolRef" },
    "action": { "type": "string", "minLength": 1 },
    "resource": { "$ref": "#/$defs/resource" },
    "decision": { "$ref": "#/$defs/decision" },
    "inputHash": { "$ref": "#/$defs/digest" }
  },
  "allOf": [
    {
      "if": { "properties": { "approved": { "const": true } } },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "effect": { "enum": ["allow", "redact"] }
            }
          }
        }
      },
      "else": {
        "properties": {
          "decision": {
            "properties": {
              "effect": { "const": "deny" },
              "reasonCode": { "const": "approval:rejected" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "decision": { "properties": { "effect": { "const": "redact" } } } } },
      "then": {
        "properties": { "decision": { "required": ["redactions"] } }
      },
      "else": {
        "properties": {
          "decision": {
            "not": { "required": ["redactions"] }
          }
        }
      }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "toolRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "digest"],
      "properties": {
        "name": { "$ref": "#/$defs/id" },
        "version": { "$ref": "#/$defs/version" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tenant", "classification"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "tenant": { "$ref": "#/$defs/id" },
        "classification": { "enum": ["public", "internal", "confidential", "restricted"] }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect", "reasonCode", "policyVersion"],
      "properties": {
        "effect": { "enum": ["allow", "deny", "redact"] },
        "reasonCode": { "$ref": "#/$defs/id" },
        "policyVersion": { "$ref": "#/$defs/version" },
        "redactions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^/(?:[^~]|~[01])*$" }
        }
      }
    }
  }
}
