{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudailab.dev/schemas/agent/v1alpha1/tool-manifest.json",
  "title": "CloudAILab Agent Tool Manifest v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "cloudailab.dev/agent/v1alpha1" },
    "kind": { "const": "ToolManifest" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "description"],
      "properties": {
        "name": { "$ref": "#/$defs/id" },
        "version": { "$ref": "#/$defs/version" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "inputSchema", "permissions", "risk", "timeoutMillis", "isolation", "sensitiveFields"],
      "properties": {
        "transport": { "$ref": "#/$defs/transport" },
        "inputSchema": { "$ref": "#/$defs/inputSchema" },
        "permissions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/permission" }
        },
        "risk": { "enum": ["low", "medium", "high", "critical"] },
        "timeoutMillis": { "type": "integer", "minimum": 100, "maximum": 300000 },
        "isolation": { "$ref": "#/$defs/isolation" },
        "sensitiveFields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^/" }
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "command"],
      "properties": {
        "type": { "const": "subprocess" },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n\\u0000]+$" }
        }
      }
    },
    "inputSchema": {
      "type": "object",
      "required": ["$schema", "type", "additionalProperties"],
      "properties": {
        "$schema": { "const": "https://json-schema.org/draft/2020-12/schema" },
        "type": { "const": "object" },
        "additionalProperties": { "const": false }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant", "actions", "resources"],
      "properties": {
        "tenant": { "$ref": "#/$defs/id" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "filesystem"],
      "properties": {
        "network": { "enum": ["none", "loopback", "host"] },
        "filesystem": { "enum": ["none", "read_only", "workspace_write", "host"] }
      }
    }
  }
}
